PORT=5000
MONGO_URI=
MONGO_USERNAME=your-atlas-username
MONGO_PASSWORD=your-atlas-password
MONGO_CLUSTER=your-cluster-host.mongodb.net
MONGO_DB_NAME=your-database-name
JWT_SECRET=replace-with-strong-secret
JWT_ISSUER=
JWT_AUDIENCE=
CLIENT_ORIGIN=https://app.your-domain.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.your-domain.com/api/auth/google/callback
NODE_ENV=production
BCRYPT_SALT_ROUNDS=12
AUTO_SEED_DATASETS=false
REDIS_URL=
CACHE_TTL_SECONDS=60
DATASET_CACHE_TTL_SECONDS=120
BLOB_READ_WRITE_TOKEN=
SEED_USER_PASSWORD=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Security hardening
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=300
MUTATION_RATE_LIMIT_WINDOW_MS=60000
MUTATION_RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=40
ADMIN_RATE_LIMIT_WINDOW_MS=60000
ADMIN_RATE_LIMIT_MAX=100
PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=900000
PASSWORD_RESET_RATE_LIMIT_MAX=20
AUTH_FAILURE_WINDOW_MS=600000
AUTH_MAX_FAILURES=5
AUTH_LOCK_MS=600000
PII_GUARD_ENABLED=false
