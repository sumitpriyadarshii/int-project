{
  "watch": ["server.js", "routes", "models", "middleware"],
  "ext": "js",
  "ignore": ["node_modules", "uploads", ".env", ".env.*"],
  "delay": 2500,
  "env": {
    "NODE_ENV": "development"
  },
  "verbose": false,
  "execMap": {"js": "node"},
  "restartable": "rs",
  "events": {
    "crash": "echo 'App crashed. Waiting for file changes before restarting...'"
  }
}
