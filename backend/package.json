{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "app.js",
  "scripts": {
    "dev": "nodemon dev-server.js",
    "start": "node dev-server.js",
    "start:prod": "powershell -NoProfile -Command \"$env:NODE_ENV='production'; node dev-server.js\"",
    "seed:datasets": "node scripts/seed-datasets.js",
    "reset:downloads": "node scripts/reset-download-counts.js",
    "clean": "powershell -NoProfile -Command \"$ports=@(5000,5173); foreach($p in $ports){ Get-NetTCPConnection -LocalPort $p -State Listen -ErrorAction SilentlyContinue | Select-Object -ExpandProperty OwningProcess -Unique | ForEach-Object { Stop-Process -Id $_ -Force -ErrorAction SilentlyContinue } }; exit 0\"",
    "clean-dev": "npm run clean && npm run dev",
    "test": "echo \"No tests configured yet\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20"
  },
  "type": "commonjs",
  "dependencies": {
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb-memory-server": "^11.0.1",
    "mongoose": "^9.4.1",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "redis": "^5.12.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
